<?xml version="1.0" encoding="utf-8"?><androidx.constraintlayout.widget.ConstraintLayout    xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:app="http://schemas.android.com/apk/res-auto"    xmlns:tools="http://schemas.android.com/tools"    android:layout_width="match_parent"    android:layout_height="wrap_content"    android:paddingStart="10dp"    android:paddingEnd="10dp"    android:paddingVertical="4dp">    <ImageView        android:id="@+id/img_combined_background_small"        android:layout_width="0dp"        android:layout_height="110dp"        android:scaleType="centerCrop"        android:paddingEnd="10dp"        app:srcCompat="@drawable/ic_note_small_combined"        android:contentDescription="日記小版縮圖背景與裝飾"        app:layout_constraintTop_toTopOf="parent"        app:layout_constraintBottom_toBottomOf="parent"        app:layout_constraintStart_toStartOf="parent"        app:layout_constraintEnd_toEndOf="parent" />    <TextView        android:id="@+id/tv_year_small"        android:layout_width="wrap_content"        android:layout_height="wrap_content"        android:layout_marginStart="200dp"        android:layout_marginBottom="50dp"        android:textSize="20sp"        android:textStyle="bold"        tools:text="2025"        app:layout_constraintStart_toStartOf="@id/img_combined_background_small"        app:layout_constraintTop_toTopOf="@id/img_combined_background_small"        app:layout_constraintBottom_toBottomOf="@id/img_combined_background_small"/>    <TextView        android:id="@+id/tv_month_day_small"        android:layout_width="wrap_content"        android:layout_height="wrap_content"        android:textSize="25sp"        android:textColor="@color/black"        android:textStyle="bold"        tools:text="05 月 29 日"        app:layout_constraintStart_toStartOf="@id/tv_year_small"        app:layout_constraintTop_toBottomOf="@id/tv_year_small" /></androidx.constraintlayout.widget.ConstraintLayout>