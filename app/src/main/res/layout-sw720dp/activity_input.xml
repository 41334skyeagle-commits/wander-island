<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".InputActivity">

    <ImageView
        android:id="@+id/noteinputbackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="日記背景圖片"
        android:scaleType="centerCrop"
        android:src="@drawable/noteinputbackground" />

    <ImageButton
        android:id="@+id/completeButton"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:background="@android:color/transparent"
        android:contentDescription="完成並儲存按鈕"
        android:scaleType="fitCenter"
        android:src="@drawable/completebutton" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/completeButton"
        android:layout_alignParentTop="true"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/dateTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="2025年10月11日"
                android:textColor="@android:color/black"
                android:textSize="30sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/emotionPromptTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="請選擇今天的心情"
                android:textColor="@android:color/black"
                android:textSize="22sp" />

            <LinearLayout
                android:id="@+id/emotionSelectorContainer"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="22dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/niceEmojiImageView"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginHorizontal="28dp"
                    android:clickable="true"
                    android:contentDescription="好"
                    android:focusable="true"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/okEmojiImageView"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginHorizontal="28dp"
                    android:clickable="true"
                    android:contentDescription="普通"
                    android:focusable="true"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/sadEmojiImageView"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginHorizontal="28dp"
                    android:clickable="true"
                    android:contentDescription="不好"
                    android:focusable="true"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <EditText
                android:id="@+id/titleEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@android:color/transparent"
                android:hint="標題"
                android:inputType="text"
                android:paddingHorizontal="8dp"
                android:paddingVertical="12dp"
                android:textAlignment="center"
                android:textColor="@android:color/black"
                android:textColorHint="#CCCCCC"
                android:textSize="32sp" />

            <ImageView
                android:id="@+id/guideWord1ImageView"
                android:layout_width="360dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:adjustViewBounds="true"
                android:contentDescription="引導語一"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/photoUploadArea"
                android:layout_width="360dp"
                android:layout_height="360dp"
                android:layout_marginBottom="14dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:contentDescription="上傳照片區域"
                android:focusable="true"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_upload_photo" />

            <ImageView
                android:id="@+id/guideWord2ImageView"
                android:layout_width="360dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:adjustViewBounds="true"
                android:contentDescription="引導語二"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/question1TextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:contentDescription="問題一"
                android:scaleType="fitStart" />

            <EditText
                android:id="@+id/content1EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top|start"
                android:hint="請寫下你的回答..."
                android:minHeight="110dp"
                android:padding="8dp"
                android:textColor="@android:color/black"
                android:textColorHint="#CCCCCC"
                android:textSize="20sp" />

            <ImageView
                android:id="@+id/question2TextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:contentDescription="問題二"
                android:scaleType="fitStart" />

            <EditText
                android:id="@+id/content2EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top|start"
                android:hint="請寫下你的回答..."
                android:minHeight="110dp"
                android:padding="8dp"
                android:textColor="@android:color/black"
                android:textColorHint="#CCCCCC"
                android:textSize="20sp" />

            <ImageView
                android:id="@+id/question3TextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:contentDescription="問題三"
                android:scaleType="fitStart" />

            <EditText
                android:id="@+id/content3EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top|start"
                android:hint="請寫下你的回答..."
                android:minHeight="110dp"
                android:padding="8dp"
                android:textColor="@android:color/black"
                android:textColorHint="#CCCCCC"
                android:textSize="20sp" />

            <ImageView
                android:id="@+id/question4ImageView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:contentDescription="問題四"
                android:scaleType="fitStart" />

            <EditText
                android:id="@+id/content4EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top|start"
                android:hint="請寫下你的回答..."
                android:minHeight="110dp"
                android:padding="8dp"
                android:textColor="@android:color/black"
                android:textColorHint="#CCCCCC"
                android:textSize="20sp" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
