<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".NoteDetailActivity">

    <ImageView
        android:id="@+id/notedetailbackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="日記詳情背景圖片"
        android:scaleType="centerCrop"
        android:src="@drawable/noteinputbackground" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp">

        <TextView
            android:id="@+id/detailDateTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="44dp"
            android:layout_marginBottom="14dp"
            android:textColor="@android:color/black"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="2025年10月11日 星期五" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="124dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/detailEmotionImageView"
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:contentDescription="心情表情"
                android:visibility="gone"
                tools:src="@drawable/niceemoji"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/detailTitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="18dp"
                android:gravity="center"
                android:paddingVertical="14dp"
                android:textColor="@android:color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="我與植物" />

            <ImageView
                android:id="@+id/detailPhotoImageView"
                android:layout_width="360dp"
                android:layout_height="360dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="10dp"
                android:background="#DDDDDD"
                android:contentDescription="日記照片"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/detailQuestion1ImageView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:adjustViewBounds="true"
                android:contentDescription="問題一"
                android:scaleType="fitStart"
                android:src="@drawable/inputq1" />

            <TextView
                android:id="@+id/detailAnswer1TextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:lineSpacingExtra="6dp"
                android:padding="16dp"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                tools:text="今天我最珍藏的是和植物一起散步。" />

            <ImageView
                android:id="@+id/detailQuestion2ImageView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:adjustViewBounds="true"
                android:contentDescription="問題二"
                android:scaleType="fitStart"
                android:src="@drawable/inputq2" />

            <TextView
                android:id="@+id/detailAnswer2TextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:lineSpacingExtra="6dp"
                android:padding="16dp"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                tools:text="覺得有點累但也很平靜。" />

            <ImageView
                android:id="@+id/detailQuestion3ImageView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:adjustViewBounds="true"
                android:contentDescription="問題三"
                android:scaleType="fitStart"
                android:src="@drawable/inputq3" />

            <TextView
                android:id="@+id/detailAnswer3TextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:lineSpacingExtra="6dp"
                android:padding="16dp"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                tools:text="我比上週更願意表達感受。" />

            <ImageView
                android:id="@+id/detailQuestion4ImageView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:adjustViewBounds="true"
                android:contentDescription="問題四"
                android:scaleType="fitStart"
                android:src="@drawable/inputq4" />

            <TextView
                android:id="@+id/detailAnswer4TextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:lineSpacingExtra="6dp"
                android:padding="16dp"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                tools:text="明天也要記得稱讚自己。" />

        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:background="@android:color/transparent"
        android:contentDescription="返回上一頁按鈕"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back_arrow" />

</RelativeLayout>
