<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/noteinputbackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="日記背景圖片"
        android:scaleType="centerCrop"
        android:src="@drawable/noteinputbackground" />

    <TextView
        android:id="@+id/dateTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="100dp"
        android:layout_marginTop="30dp"
        android:text="2025年10月11日"
        android:textColor="@android:color/black"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="100dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="6dp">

            <TextView
                android:id="@+id/emotionPromptTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="1dp"
                android:text=""
                android:textColor="@android:color/black"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/emotionSelectorContainer"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/niceEmojiImageView"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_marginHorizontal="20dp"
                    android:clickable="true"
                    android:contentDescription="好"
                    android:focusable="true"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/okEmojiImageView"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_marginHorizontal="20dp"
                    android:clickable="true"
                    android:contentDescription="普通"
                    android:focusable="true"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/sadEmojiImageView"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_marginHorizontal="20dp"
                    android:clickable="true"
                    android:contentDescription="不好"
                    android:focusable="true"
                    android:scaleType="fitCenter" />

            </LinearLayout>

            <EditText
                android:id="@+id/titleEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@android:color/transparent"
                android:hint="標題"
                android:inputType="text"
                android:paddingHorizontal="8dp"
                android:paddingVertical="12dp"
                android:textAlignment="center"
                android:textColor="@android:color/black"
                android:textColorHint="#CCCCCC" />

            <ImageView
                android:id="@+id/guideWord1ImageView"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:adjustViewBounds="true"
                android:contentDescription="引導語一"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/photoUploadArea"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:layout_marginBottom="12dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:contentDescription="上傳照片區域"
                android:focusable="true"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_upload_photo" />

            <ImageView
                android:id="@+id/guideWord2ImageView"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:adjustViewBounds="true"
                android:contentDescription="引導語二"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/upSwipeHintImageView"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="24dp"
                android:contentDescription="上滑切換下一頁"
                android:src="@drawable/up_inputpage1" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
